# M.A.S.T.E.R. System - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# LLM Providers (at least one required)
# ============================================

# OpenAI API (GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API (Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek API (deepseek-chat, deepseek-coder)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Moonshot API (Kimi)
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# Alibaba DashScope (Qwen models)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ByteDance Doubao (requires volcano engine API)
DOUBAO_API_KEY=your-doubao-key-here

# ============================================
# Search Providers (at least one recommended)
# ============================================

# Tavily - AI-powered search (recommended)
# Get free API key: https://tavily.com/
TAVILY_API_KEY=your-tavily-key-here

# Brave Search API
# Get API key: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-key-here

# Serper.dev - Google Search API
# Get API key: https://serper.dev/
SERPER_API_KEY=your-serper-key-here

# DuckDuckGo - No API key needed (free, rate limited)

# ============================================
# Server Configuration
# ============================================

API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000