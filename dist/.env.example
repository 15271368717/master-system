# M.A.S.T.E.R. System 环境变量

# ===================
# AI 服务 API Keys
# ===================

# OpenAI (GPT-4/GPT-3.5)
# 获取: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude)
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# DeepSeek
# 获取: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 豆包 (字节跳动)
# 获取: https://www.doubao.com/
DOUBAO_API_KEY=

# ===================
# 服务配置 (一般不需要改)
# ===================

API_PORT=8000
FRONTEND_PORT=3000

# ===================
# 浏览器自动化 (可选)
# ===================

# 如需使用浏览器自动化，配置以下选项
# BROWSER_AUTOMATION=true
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe